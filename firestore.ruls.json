rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }
    
    match /leaderboard/{scoreId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId);
    }
    
    match /scores/{skin}/entries/{scoreId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId);
    }
    
    match /userStats/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    match /moneyLeaderboard/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId);
    }

    // Education sessions: shared "classroom" state used for the 45-minute lock,
    // remote unlock-all, and the "who is connected / locked" dashboard.
    // Students may be anonymous, so access is open (obfuscation-only security:
    // the session id is just a hash of a teacher-chosen password).
    match /eduSessions/{sessionId} {
      allow read, write: if true;
      match /participants/{clientId} {
        allow read, write: if true;
      }
    }

    match /speedrun/{goalKey}/entries/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId);
    }

    match /game_sessions/{docId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // Peer-to-peer coin transfers: a sender creates a transfer addressed to a
    // recipient's email; the recipient claims it (marks claimed) on next login.
    match /coinTransfers/{transferId} {
      // Sender or recipient may read their own transfers (recipient queries by toEmail).
      allow read: if isSignedIn() &&
        (resource.data.fromUid == request.auth.uid ||
         resource.data.toEmail == request.auth.token.email);
      // Only the authenticated sender can create, and the transfer must start unclaimed.
      allow create: if isSignedIn() &&
        request.resource.data.fromUid == request.auth.uid &&
        request.resource.data.claimed == false &&
        request.resource.data.amount is number &&
        request.resource.data.amount > 0;
      // Only the recipient may update, and only to claim an unclaimed transfer.
      allow update: if isSignedIn() &&
        resource.data.toEmail == request.auth.token.email &&
        resource.data.claimed == false &&
        request.resource.data.claimed == true &&
        request.resource.data.amount == resource.data.amount;
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }

    // Analytics: full game sessions + event logs.
    // Write is open so anonymous players can also be tracked.
    // Read is restricted to the session owner only.
    match /gameSessions/{sessionId} {
      allow create: if true;
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.userId == 'anonymous');
      allow update, delete: if false;

      match /logs/{logId} {
        allow create: if true;
        allow read: if isSignedIn() && get(/databases/$(database)/documents/gameSessions/$(sessionId)).data.userId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // Per-user analytics index (quick queries by user)
    match /userAnalytics/{userId}/sessions/{sessionId} {
      allow read, write: if isOwner(userId);
    }
  }
}