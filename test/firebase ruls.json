rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }
    
    match /leaderboard/{scoreId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId);
    }
    
    match /scores/{skin}/entries/{scoreId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId);
    }
    
    match /userStats/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // Education sessions: shared "classroom" state used for the 45-minute lock,
    // remote unlock-all, and the "who is connected / locked" dashboard.
    // Students may be anonymous, so access is open (obfuscation-only security:
    // the session id is just a hash of a teacher-chosen password).
    match /eduSessions/{sessionId} {
      allow read, write: if true;
      match /participants/{clientId} {
        allow read, write: if true;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}